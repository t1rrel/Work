#define F_CPU 4000000UL

#include <avr/io.h>
#include <avr/interrupt.h>
#include <stdbool.h>
#include <stdint.h>

// ---------------- UART ----------------
#define BAUD 9600
#define UBRR_VALUE ((F_CPU/16/BAUD)-1)

#define RX_BUF_SIZE 32
#define TX_BUF_SIZE 16

#define RESPONSE_TIMEOUT 5  // ñåêóíä îæèäàíèÿ îòâåòà

volatile uint8_t rx_buf[RX_BUF_SIZE];
volatile uint8_t rx_head = 0;
volatile uint8_t rx_count = 0;

volatile uint8_t tx_buf[TX_BUF_SIZE];
volatile uint8_t tx_len = 0;
volatile uint8_t tx_pos = 0;

volatile uint16_t resp_timer = 0;

// ---------------- TIMER ----------------
volatile uint16_t seconds = 0;

// ---------------- FLAGS ----------------
volatile bool trigger = false;

// ---------------- FSM ----------------
typedef enum {
	IDLE,
	SEND_REQ,
	WAIT_RESP,
	WAIT_30MIN,
	COMPARE
} state_t;

volatile state_t state = IDLE;

// ---------------- DATA ----------------
uint16_t v1 = 0;
uint16_t v2 = 0;

// ---------------- UART INIT ----------------
void UART_init(void) {
	UBRRH = (uint8_t)(UBRR_VALUE >> 8);
	UBRRL = (uint8_t)UBRR_VALUE;

	UCSRB = (1 << RXEN) | (1 << TXEN) | (1 << RXCIE); // RX interrupt
	UCSRC = (1 << URSEL) | (1 << UCSZ1) | (1 << UCSZ0);
}

// ---------------- UART SEND (IRQ) ----------------
void UART_send(uint8_t *data, uint8_t len) {
	for (uint8_t i = 0; i < len; i++) {
		tx_buf[i] = data[i];
	}

	tx_len = len;
	tx_pos = 0;

	UCSRB |= (1 << UDRIE); // âêëþ÷àåì ïðåðûâàíèå ïåðåäà÷è
}

ISR(USART_UDRE_vect) {
	if (tx_pos < tx_len) {
		UDR = tx_buf[tx_pos++];
		} else {
		UCSRB &= ~(1 << UDRIE); // âûêëþ÷àåì
	}
}

// ---------------- UART RX ----------------
ISR(USART_RXC_vect) {
	uint8_t data = UDR;

	if (rx_count < RX_BUF_SIZE) {
		rx_buf[rx_head++] = data;
		rx_head %= RX_BUF_SIZE;
		rx_count++;
	}
}

// ---------------- TIMER1 ----------------
ISR(TIMER1_COMPA_vect) {
	seconds++;
	resp_timer++;
}

void TIMER1_init(void) {
	TCCR1B |= (1 << WGM12);
	TCCR1B |= (1 << CS12) | (1 << CS10);

	OCR1A = 3906;
	TIMSK |= (1 << OCIE1A);
}

// ---------------- INT0 ----------------
ISR(INT0_vect) {
	trigger = true;
}

// ---------------- PARSE ----------------
uint16_t parse_value(uint8_t *buf) {
	uint16_t value = 0;

	for (uint8_t i = 11; i <= 13; i++) {
		if (buf[i] >= '0' && buf[i] <= '9') {
			value = value * 10 + (buf[i] - '0');
		}
	}

	return value;
}

// ---------------- CHECK RESPONSE ----------------
bool get_packet(uint8_t *out) {
	if (rx_count >= 15) {
		for (uint8_t i = 0; i < 15; i++) {
			out[i] = rx_buf[(rx_head + RX_BUF_SIZE - rx_count + i) % RX_BUF_SIZE];
		}
		rx_count -= 15;
		return true;
	}
	return false;
}

// ---------------- MAIN ----------------
int main(void) {

	DDRD &= ~(1 << PD2);
	DDRC |= (1 << PC5);
	PORTC &= ~(1 << PC5);

	// INT0 ïî ôðîíòó
	MCUCR |= (1 << ISC01) | (1 << ISC00);
	GICR |= (1 << INT0);

	UART_init();
	TIMER1_init();

	sei();

	uint8_t request[5] = {0x26,0x30,0x31,0x31,0x0D};
	uint8_t resp[15];

	while (1) {

		switch (state) {

			case IDLE:
			if (trigger) {
				trigger = false;
				state = SEND_REQ;
			}
			break;

			case SEND_REQ:
			UART_send(request, 5);
			resp_timer = 0;
			state = WAIT_RESP;
			break;

			case WAIT_RESP:
			// åñòü ïàêåò
			if (get_packet(resp)) {
				v1 = parse_value(resp);
				seconds = 0;
				state = WAIT_30MIN;
			}

			// òàéìàóò
			else if (resp_timer >= RESPONSE_TIMEOUT) {
				// ìîæíî:
				// state = IDLE;         // âàðèàíò 1
				// èëè ïîâòîðèòü:
				state = SEND_REQ;       // âàðèàíò 2 (ðåêîìåíäóþ)
			}

			break;

			case WAIT_30MIN:
			if (seconds >= 1800) {
				UART_send(request, 5);
				state = COMPARE;
			}
			break;

			case COMPARE:

			if (get_packet(resp)) {
				v2 = parse_value(resp);

				uint16_t diff = (v1 > v2) ? (v1 - v2) : (v2 - v1);

				if (v1 != 0 && (uint32_t)diff * 100 < v1) {
					PORTC |= (1 << PC5);
					state = IDLE;
					} else {
					v1 = v2;
					seconds = 0;
					state = WAIT_30MIN;
				}
			}

			else if (resp_timer >= RESPONSE_TIMEOUT) {
				// ïîâòîð çàïðîñà
				state = SEND_REQ;
			}

			break;
		}
	}
}
